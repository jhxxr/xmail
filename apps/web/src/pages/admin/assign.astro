---
import AdminLayout from "../../layouts/AdminLayout.astro"
import { createDB, getAdminById, listUsers, listMailboxes, getUserById, assignMailboxToUser, assignMailboxesToUser, createLog } from "database"
import { verifyToken } from "../../lib/auth"
import { Card, CardContent, CardHeader, CardTitle } from "../../components/ui/card"
import { Button } from "../../components/ui/button"
import { Badge } from "../../components/ui/badge"
import { User, Mail, Link as LinkIcon, Unlink, CheckSquare, Square } from "lucide-react"

const db = createDB(Astro.locals.runtime.env.DB)
const jwtSecret = Astro.locals.runtime.env.JWT_SECRET

// 验证登录
const token = Astro.cookies.get("admin_token")?.value
if (!token) return Astro.redirect("/admin/login")
const payload = await verifyToken(token, jwtSecret)
if (!payload || payload.type !== "admin") return Astro.redirect("/admin/login")
const admin = await getAdminById(db, payload.id)
if (!admin) return Astro.redirect("/admin/login")

let message = ""
let messageType: "success" | "error" = "success"

// 处理表单
if (Astro.request.method === "POST") {
  const formData = await Astro.request.formData()
  const action = formData.get("action")?.toString()

  if (action === "assign") {
    const userId = formData.get("user_id")?.toString()
    const addresses = formData.getAll("addresses").map(a => a.toString())
    if (userId && addresses.length > 0) {
      await assignMailboxesToUser(db, addresses, userId)
      await createLog(db, { adminId: admin.id, action: "assign_mailboxes", target: userId, details: { count: addresses.length } })
      message = `已分配 ${addresses.length} 个邮箱`
      messageType = "success"
    }
  } else if (action === "unassign") {
    const address = formData.get("address")?.toString()
    if (address) {
      await assignMailboxToUser(db, address, null)
      await createLog(db, { adminId: admin.id, action: "unassign_mailbox", target: address })
      message = `已取消分配`
    }
  }
}

const selectedUserId = Astro.url.searchParams.get("user")
const users = await listUsers(db, { limit: 100 })
const selectedUser = selectedUserId ? await getUserById(db, selectedUserId) : null
const unassignedMailboxes = await listMailboxes(db, { limit: 100, unassignedOnly: true })
const userMailboxes = selectedUserId ? await listMailboxes(db, { limit: 100, userId: selectedUserId }) : []
---

<AdminLayout title="分配管理">
  <div class="space-y-6">
    <h1 class="text-3xl font-bold tracking-tight">分配管理</h1>

    {message && (
      <div class={`p-4 rounded-md border ${messageType === "success" ? "bg-green-50 text-green-900 border-green-200" : "bg-red-50 text-red-900 border-red-200"}`}>
        {message}
      </div>
    )}

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
      <!-- 选择用户 -->
      <Card className="h-full flex flex-col">
        <CardHeader>
          <CardTitle className="flex items-center gap-2">
            <User className="h-5 w-5" />
            选择用户
          </CardTitle>
        </CardHeader>
        <CardContent className="flex-1 overflow-hidden flex flex-col">
          <div class="space-y-2 overflow-y-auto pr-2 flex-1 max-h-[400px]">
            {users.length === 0 ? (
              <p class="text-muted-foreground text-center py-8">暂无用户，请先 <a href="/admin/users?action=create" class="text-primary underline">创建用户</a></p>
            ) : (
              users.map((user) => (
                <a
                  href={`/admin/assign?user=${user.id}`}
                  class={`block p-3 rounded-md border transition-colors ${selectedUserId === user.id ? "border-primary bg-primary/5" : "hover:bg-muted"}`}
                >
                  <div class="flex justify-between items-center">
                    <div class="font-medium">{user.name || "未命名"}</div>
                    {selectedUserId === user.id && <Badge variant="default" className="h-5 text-[10px]">已选</Badge>}
                  </div>
                  <div class="text-xs text-muted-foreground mt-1 truncate">{user.note || user.token.slice(0, 16) + "..."}</div>
                </a>
              ))
            )}
          </div>
        </CardContent>
      </Card>

      <!-- 用户已分配的邮箱 -->
      <Card className="h-full flex flex-col">
        <CardHeader>
          <CardTitle className="flex items-center gap-2">
            <Mail className="h-5 w-5" />
            {selectedUser ? `${selectedUser.name || "用户"} 的邮箱` : "已分配邮箱"}
          </CardTitle>
        </CardHeader>
        <CardContent className="flex-1 overflow-hidden flex flex-col">
          {!selectedUser ? (
            <div class="flex flex-col items-center justify-center h-full text-muted-foreground py-8">
              <User className="h-12 w-12 mb-2 opacity-20" />
              <p>请先从左侧选择一个用户</p>
            </div>
          ) : userMailboxes.length === 0 ? (
            <div class="flex flex-col items-center justify-center h-full text-muted-foreground py-8">
              <Mail className="h-12 w-12 mb-2 opacity-20" />
              <p>该用户暂无邮箱</p>
            </div>
          ) : (
            <div class="space-y-2 overflow-y-auto pr-2 flex-1 max-h-[400px]">
              {userMailboxes.map((mb) => (
                <div class="flex justify-between items-center p-3 bg-muted/50 rounded-md border">
                  <span class="font-mono text-sm">{mb.address}</span>
                  <form method="POST">
                    <input type="hidden" name="action" value="unassign" />
                    <input type="hidden" name="address" value={mb.address} />
                    <Button variant="ghost" size="sm" className="h-8 text-destructive hover:text-destructive hover:bg-destructive/10">
                      <Unlink className="h-4 w-4 mr-1" />
                      取消
                    </Button>
                  </form>
                </div>
              ))}
            </div>
          )}
        </CardContent>
      </Card>
    </div>

    <!-- 分配未分配的邮箱 -->
    {selectedUser && (
      <Card>
        <CardHeader>
          <CardTitle className="flex items-center gap-2">
            <LinkIcon className="h-5 w-5" />
            分配邮箱给 {selectedUser.name || "用户"}
          </CardTitle>
        </CardHeader>
        <CardContent>
          {unassignedMailboxes.length === 0 ? (
            <p class="text-muted-foreground text-center py-8">没有未分配的邮箱，请先 <a href="/admin/mailboxes" class="text-primary underline">生成邮箱</a></p>
          ) : (
            <form method="POST">
              <input type="hidden" name="action" value="assign" />
              <input type="hidden" name="user_id" value={selectedUser.id} />
              <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-3 max-h-64 overflow-y-auto mb-6 p-1">
                {unassignedMailboxes.map((mb) => (
                  <label class="flex items-center gap-3 p-3 rounded-md border cursor-pointer hover:bg-muted transition-colors relative group">
                    <input type="checkbox" name="addresses" value={mb.address} class="peer sr-only" />
                    <div class="h-4 w-4 rounded border border-primary flex items-center justify-center peer-checked:bg-primary peer-checked:text-primary-foreground transition-colors">
                      <CheckSquare className="h-3 w-3 opacity-0 peer-checked:opacity-100" />
                    </div>
                    <span class="font-mono text-sm truncate flex-1">{mb.address}</span>
                    <div class="absolute inset-0 rounded-md ring-2 ring-primary opacity-0 peer-checked:opacity-100 pointer-events-none transition-opacity"></div>
                  </label>
                ))}
              </div>
              <div class="flex gap-4">
                <Button type="submit">
                  分配选中的邮箱
                </Button>
                <Button type="button" variant="secondary" onclick="document.querySelectorAll('input[name=addresses]').forEach(c => c.checked = true)">
                  全选
                </Button>
              </div>
            </form>
          )}
        </CardContent>
      </Card>
    )}
  </div>
</AdminLayout>
